---
import ThemeToggle from "@components/theme-toggle.astro";

const url = new URL(Astro.request.url);
const isHome = url.pathname === "/";
---

<header class="mb-10 flex items-center justify-between gap-4">
  <a
    href="/"
    aria-label="dotfiles home"
    class="flex items-center gap-3 wavy-hover"
  >
    <img src="/logo.svg" alt="" width="32" height="32" class="rounded" />
    <span class="primary text-base">dotfiles</span>
  </a>

  <nav aria-label="Main menu" class="flex items-center gap-4 text-xs">
    <a
      href="/"
      class={`wavy-hover primary ${isHome ? "wavy-underline" : ""}`}
      data-astro-prefetch>tree</a
    >
    <a
      href="https://github.com/hbeneke/dotfiles"
      class="secondary-link"
      target="_blank"
      rel="noopener noreferrer">github</a
    >
    <ThemeToggle />
  </nav>
</header>
