{
  "name": "@habakukbeneke/dotfiles",
  "version": "0.1.1",
  "description": "Personal dotfiles + tooling, synced across machines via Git, browsable as a static Astro site.",
  "author": {
    "name": "Enrique Quero Vilar",
    "nickname": "Habakuk Beneke",
    "e-mail": "habakukBeneke [at] proton [dot] me"
  },
  "keywords": [
    "dotfiles",
    "claude-code",
    "neovim",
    "astronvim",
    "git-flow",
    "astro"
  ],
  "private": true,
  "type": "module",
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/hbeneke/dotfiles.git"
  },
  "homepage": "https://github.com/hbeneke/dotfiles#readme",
  "bugs": {
    "url": "https://github.com/hbeneke/dotfiles/issues"
  },
  "scripts": {
    "dev": "npm --prefix web run dev",
    "host": "npm --prefix web run host",
    "build": "npm --prefix web run build",
    "preview": "npm --prefix web run preview",
    "lint": "npm --prefix web run lint",
    "install:web": "npm --prefix web install",
    "hooks:install": "node scripts/install-hooks.mjs",
    "hooks:uninstall": "node scripts/uninstall-hooks.mjs",
    "sync:master": "node scripts/sync-master.mjs",
    "prepare": "node scripts/install-hooks.mjs"
  }
}
