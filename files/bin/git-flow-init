#!/usr/bin/env node

import { execSync } from "node:child_process";
import {
  copyFileSync,
  chmodSync,
  existsSync,
  mkdirSync,
  readFileSync,
  readdirSync,
  writeFileSync,
} from "node:fs";
import { dirname, join, resolve } from "node:path";
import { fileURLToPath } from "node:url";

const SCRIPT_DIR = dirname(fileURLToPath(import.meta.url));
const DOTFILES_DIR = resolve(SCRIPT_DIR, "..");
const TEMPLATE_DIR = join(DOTFILES_DIR, "git-flow");
const HOOKS_SRC = join(TEMPLATE_DIR, ".githooks");
const SCRIPTS_SRC = join(TEMPLATE_DIR, "scripts");

const args = process.argv.slice(2);
const force = args.includes("--force");
const help = args.includes("--help") || args.includes("-h");
const positional = args.filter((a) => !a.startsWith("-"));
const targetArg = positional[0] || ".";
const TARGET = resolve(process.cwd(), targetArg);

const NPM_SCRIPTS = {
  "hooks:install": "node scripts/install-hooks.mjs",
  "hooks:uninstall": "node scripts/uninstall-hooks.mjs",
  "sync:master": "node scripts/sync-master.mjs",
  "sync:minor": "node scripts/sync-master.mjs --minor",
  "sync:patch": "node scripts/sync-master.mjs --patch",
  "sync:no-tag": "node scripts/sync-master.mjs --no-tag",
};

if (help) {
  console.log(`git-flow-init — bootstrap master/develop git-flow into a project

Usage:
  git-flow-init [target] [--force]

Args:
  target      Path to project (default: current directory)
  --force     Overwrite existing hook/script files in target
`);
  process.exit(0);
}

const log = (msg) => console.log(`  ${msg}`);
const fail = (msg) => {
  console.error(`Error: ${msg}`);
  process.exit(1);
};

const run = (cmd, opts = {}) =>
  execSync(cmd, { cwd: TARGET, encoding: "utf8", stdio: "pipe", ...opts });

const tryRun = (cmd) => {
  try {
    return run(cmd).trim();
  } catch {
    return null;
  }
};

console.log(`Bootstrapping git-flow into: ${TARGET}\n`);

if (!existsSync(TARGET)) fail(`target does not exist: ${TARGET}`);
if (!existsSync(join(TARGET, ".git"))) fail("target is not a git repository");
if (!existsSync(join(TARGET, "package.json"))) fail("target has no package.json");

const copyTemplate = (srcDir, destDir, label) => {
  if (!existsSync(destDir)) mkdirSync(destDir, { recursive: true });
  let copied = 0;
  let skipped = 0;
  for (const file of readdirSync(srcDir)) {
    const src = join(srcDir, file);
    const dest = join(destDir, file);
    if (existsSync(dest) && !force) {
      log(`skip ${label}/${file} (exists, use --force to overwrite)`);
      skipped++;
      continue;
    }
    copyFileSync(src, dest);
    try {
      chmodSync(dest, 0o755);
    } catch {}
    log(`copy ${label}/${file}`);
    copied++;
  }
  return { copied, skipped };
};

console.log("[1/4] Copying templates");
copyTemplate(HOOKS_SRC, join(TARGET, ".githooks"), ".githooks");
copyTemplate(SCRIPTS_SRC, join(TARGET, "scripts"), "scripts");

console.log("\n[2/4] Updating package.json scripts");
const pkgPath = join(TARGET, "package.json");
const pkgRaw = readFileSync(pkgPath, "utf8");
const pkg = JSON.parse(pkgRaw);
pkg.scripts = pkg.scripts || {};
let added = 0;
let kept = 0;
for (const [name, cmd] of Object.entries(NPM_SCRIPTS)) {
  if (pkg.scripts[name] && !force) {
    log(`keep "${name}" (already set: ${pkg.scripts[name]})`);
    kept++;
  } else {
    pkg.scripts[name] = cmd;
    log(`set  "${name}": "${cmd}"`);
    added++;
  }
}
const trailingNewline = pkgRaw.endsWith("\n") ? "\n" : "";
writeFileSync(pkgPath, `${JSON.stringify(pkg, null, 2)}${trailingNewline}`);

console.log("\n[3/4] Installing hooks");
try {
  const out = run("node scripts/install-hooks.mjs", { stdio: "pipe" });
  process.stdout.write(out);
} catch (err) {
  console.error(err.stdout?.toString() || err.message);
  fail("hooks:install failed");
}

console.log("\n[4/4] Ensuring develop branch");
const branches = tryRun("git branch --list develop");
if (branches) {
  log("develop already exists");
} else {
  const head = tryRun("git rev-parse HEAD");
  if (!head) {
    log("repo has no commits yet — develop will be created after first commit");
  } else {
    tryRun("git branch develop");
    log("created develop branch");
  }
}

console.log("\nDone.");
console.log(`  Templates copied to ${TARGET}`);
console.log(`  package.json: ${added} script(s) added, ${kept} kept`);
console.log("\nNext steps:");
console.log("  git checkout develop   # work on develop");
console.log("  npm run sync:master    # merge develop → master with version bump + tag");
